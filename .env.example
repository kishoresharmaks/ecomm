# IndiHub Phase 1 environment template

# Database
# Runtime API/worker connection. In production this should be the managed
# provider's PgBouncer/pooler URL when available.
DATABASE_URL="postgresql://postgres:12345@localhost:5432/indihub?schema=public"
# Direct primary database URL for Prisma migrations and one-off operations.
# Leave empty locally if DATABASE_URL already points directly to PostgreSQL.
DATABASE_DIRECT_URL=""
# Optional read-replica URL for later scale work. Do not use replicas for
# checkout, payments, inventory, admin sessions, or payout writes.
DATABASE_READ_URL=""
# Seed safety. Default schema mode is read-only and creates no data.
# Use explicit CLI scripts for approved setup only:
# pnpm db:seed:system    -> RBAC system rows only
# pnpm db:seed:bootstrap -> default local/dev bootstrap rows
INDIHUB_SEED_MODE="schema"
INDIHUB_ENV="development"
INDIHUB_ALLOW_PRODUCTION_SEED="false"

# Public web app
NEXT_PUBLIC_APP_NAME="IndiHub"
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Local frontend dev auth headers for non-admin portals, optional until Clerk frontend sessions are configured.
# Admin uses standalone admin login below and does not use this local-dev header flow.
NEXT_PUBLIC_INDIHUB_DEV_SELLER_USER_ID=""
NEXT_PUBLIC_INDIHUB_DEV_CUSTOMER_USER_ID=""
NEXT_PUBLIC_INDIHUB_DEV_BUSINESS_BUYER_USER_ID=""

# Map location picker. OSM_LEAFLET is free-first for local/dev/low-volume use.
# For production traffic, switch tiles to Mapbox/MapTiler/TomTom/self-hosted.
NEXT_PUBLIC_MAP_PROVIDER="OSM_LEAFLET"
NEXT_PUBLIC_MAP_TILE_URL=""
NEXT_PUBLIC_MAP_ATTRIBUTION=""
# Public browser token only if using a hosted tile provider that needs one.
NEXT_PUBLIC_MAPBOX_TOKEN=""

# Optional backend reverse geocoding fallback. Prefer saving Mapbox token from
# admin map-routing settings; keep server tokens out of NEXT_PUBLIC_* values.
MAPBOX_TOKEN=""
MAPBOX_ACCESS_TOKEN=""

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Optional but recommended for local/offline API token verification.
# Paste the Clerk JWT public key PEM from the same Clerk application as the keys above.
CLERK_JWT_KEY=""
CLERK_JWT_AUDIENCE=""
CLERK_AUTHORIZED_PARTIES=""
# Local dev tolerance for small Windows/Clerk clock drift.
CLERK_JWT_CLOCK_SKEW_MS="120000"
CLERK_WEBHOOK_SECRET=""

# API
API_PORT="4000"
API_CORS_ORIGINS="http://localhost:3000"
INDIHUB_AUTH_SYNC_SECRET=""
INDIHUB_BOOTSTRAP_SECRET=""
INDIHUB_FIRST_ADMIN_EMAIL=""
INDIHUB_FIRST_ADMIN_NAME="IndiHub Admin"
# Standalone admin portal login. Keep this backend-only and change it after first setup.
INDIHUB_FIRST_ADMIN_PASSWORD=""
ADMIN_SESSION_TTL_HOURS="8"

# Redis / jobs
REDIS_URL="redis://localhost:6379"

# Admin-managed provider values should normally be saved from
# /admin/settings/general. Uncomment the following provider variables only when
# you need a bootstrap/legacy fallback before the admin panel is configured.

# Public images fallback
# PUBLIC_IMAGE_PROVIDER="IMAGEKIT"
# PUBLIC_IMAGE_BASE_URL="https://ik.imagekit.io/your_imagekit_id"
# IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your_imagekit_id"
# IMAGEKIT_PUBLIC_KEY=""
# IMAGEKIT_PRIVATE_KEY=""

# Free reference-rate currency conversion
FX_PROVIDER="frankfurter"
FX_BASE_CURRENCY="INR"
FX_CACHE_TTL_MINUTES="360"

# India pincode import from Department of Posts / data.gov.in
DATAGOVINDIA_API_KEY=""

# Private files fallback, only if needed in Phase 1
# S3_ENDPOINT=""
# S3_REGION=""
# S3_BUCKET=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# Razorpay fallback values. Prefer managing Razorpay/COD settings from /admin/settings/general after setup.
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""
# RAZORPAY_WEBHOOK_SECRET=""

# Transactional email fallback values. Prefer /admin/settings/general -> Email for normal operation.
# EMAIL_PROVIDER="smtp"
# EMAIL_FROM_NAME="IndiHub"
# EMAIL_FROM_ADDRESS="no-reply@example.com"
# EMAIL_ADMIN_RECIPIENTS=""
# BREVO_API_KEY=""
# RESEND_API_KEY=""
# SENDGRID_API_KEY=""
# SMTP_BRIDGE_URL=""

# Observability
SENTRY_DSN=""
