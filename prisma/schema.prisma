model NotificationTemplate {
  id             String                @id @default(uuid()) @db.Uuid
  code           String                @unique
  name           String                @default("")
  category       EmailTemplateCategory @default(SYSTEM)
  channel        NotificationChannel
  subject        String
  body           String
  status         ContentStatus         @default(DRAFT)
  themeId        String?               @map("theme_id") @db.Uuid
  styleOverrides Json?                 @map("style_overrides")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  theme          EmailTheme?           @relation(fields: [themeId], references: [id], onDelete: SetNull)
  triggerRules   EmailTriggerRule[]

  @@index([category])
  @@index([channel])
  @@index([status])
  @@index([channel, category, status])
  @@index([themeId])
  @@map("notification_templates")
}

model EmailTriggerRule {
  id            String                @id @default(uuid()) @db.Uuid
  eventCode     String                @map("event_code")
  recipientType EmailRecipientType    @map("recipient_type")
  category      EmailTemplateCategory
  templateId    String?               @map("template_id") @db.Uuid
  isEnabled     Boolean               @default(true) @map("is_enabled")
  delayMinutes  Int                   @default(0) @map("delay_minutes")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  template      NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  logs          NotificationLog[]

  @@unique([eventCode, recipientType])
  @@index([category])
  @@index([templateId])
  @@index([isEnabled])
  @@index([category, isEnabled])
  @@index([category, eventCode, recipientType])
  @@map("email_trigger_rules")
}

