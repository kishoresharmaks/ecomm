model User {
  id                 String               @id @default(uuid()) @db.Uuid
  clerkUserId        String?              @unique @map("clerk_user_id")
  email              String               @unique
  phone              String?
  fullName           String?              @map("full_name")
  status             UserStatus           @default(ACTIVE)
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  customer           Customer?
  seller             Seller?
  businessBuyer      BusinessBuyer?
  userRoles          UserRole[]
  inventoryMovements InventoryMovement[]
  orderStatusEvents  OrderStatusEvent[]
  deliveryEvents     DeliveryEvent[]
  assignedDeliveries DeliveryDetail[]     @relation("DeliveryPartnerAssignments")
  assignedShipments  OrderShipment[]      @relation("ShipmentDeliveryPartnerAssignments")
  codCollections     DeliveryDetail[]     @relation("DeliveryCodCollectedBy")
  shipmentCodCollections OrderShipment[]  @relation("ShipmentCodCollectedBy")
  codVerifications   DeliveryDetail[]     @relation("DeliveryCodVerifiedBy")
  shipmentCodVerifications OrderShipment[] @relation("ShipmentCodVerifiedBy")
  courierCodRemittanceVerifications CourierCodRemittance[] @relation("CourierCodRemittanceVerifiedBy")
  deliveryProfile    DeliveryPartnerProfile?
  deliveryAssignmentAttempts DeliveryAssignmentAttempt[] @relation("DeliveryAssignmentAttemptPartner")
  createdDeliveryAssignmentAttempts DeliveryAssignmentAttempt[] @relation("DeliveryAssignmentAttemptAssignedBy")
  deliveryAttempts   DeliveryAttempt[]
  deliveryWalletEntries DeliveryPartnerWalletEntry[] @relation("DeliveryPartnerWalletEntries")
  createdDeliveryWalletEntries DeliveryPartnerWalletEntry[] @relation("DeliveryPartnerWalletEntryCreatedBy")
  deliveryPartnerPayouts DeliveryPartnerPayout[] @relation("DeliveryPartnerPayoutPartner")
  requestedDeliveryPartnerPayouts DeliveryPartnerPayout[] @relation("DeliveryPartnerPayoutRequestedBy")
  approvedDeliveryPartnerPayouts DeliveryPartnerPayout[] @relation("DeliveryPartnerPayoutApprovedBy")
  paidDeliveryPartnerPayouts DeliveryPartnerPayout[] @relation("DeliveryPartnerPayoutPaidBy")
  deliveryPartnerApplications DeliveryPartnerApplication[] @relation("DeliveryPartnerApplicationApplicant")
  reviewedDeliveryPartnerApplications DeliveryPartnerApplication[] @relation("DeliveryPartnerApplicationReviewer")
  b2bResponses       B2BEnquiryResponse[]
  supportRequests    SupportRequest[]
  notificationLogs   NotificationLog[]
  auditLogs          AuditLog[]
  adminCredential    AdminCredential?
  adminSessions      AdminSession[]

  @@index([status, createdAt])
  @@map("users")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  code            RoleCode         @unique
  name            String
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @unique
  name            String
  module          String
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model AdminCredential {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @unique @map("user_id") @db.Uuid
  passwordHash      String    @map("password_hash")
  passwordSalt      String    @map("password_salt")
  passwordAlgorithm String    @default("scrypt") @map("password_algorithm")
  passwordUpdatedAt DateTime  @default(now()) @map("password_updated_at")
  failedLoginCount  Int       @default(0) @map("failed_login_count")
  lockedUntil       DateTime? @map("locked_until")
  lastLoginAt       DateTime? @map("last_login_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lockedUntil])
  @@map("admin_credentials")
}

model AdminSession {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  lastUsedAt DateTime  @default(now()) @map("last_used_at")
  userAgent  String?   @map("user_agent")
  ipAddress  String?   @map("ip_address")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("admin_sessions")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Customer {
  id          String            @id @default(uuid()) @db.Uuid
  userId      String            @unique @map("user_id") @db.Uuid
  displayName String?           @map("display_name")
  status      UserStatus        @default(ACTIVE)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  addresses   CustomerAddress[]
  wishlist    Wishlist?
  carts       Cart[]
  orders      Order[]

  @@index([status, createdAt])
  @@map("customers")
}

model CustomerAddress {
  id            String   @id @default(uuid()) @db.Uuid
  customerId    String   @map("customer_id") @db.Uuid
  label         String?
  fullName      String   @map("full_name")
  phone         String
  line1         String
  line2         String?
  area          String?
  city          String
  state         String
  pincode       String
  country       String   @default("India")
  countryCode   String   @default("IN") @map("country_code")
  stateCode     String?  @map("state_code")
  cityCode      String?  @map("city_code")
  localAreaCode String?  @map("local_area_code")
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  locationSource LocationSource? @map("location_source")
  accuracyMeters Decimal? @map("accuracy_meters") @db.Decimal(10, 2)
  locationConfidenceScore Decimal? @map("location_confidence_score") @db.Decimal(5, 2)
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([city, pincode])
  @@index([countryCode, stateCode, cityCode])
  @@index([latitude, longitude])
  @@map("customer_addresses")
}

model Wishlist {
  id         String         @id @default(uuid()) @db.Uuid
  customerId String         @unique @map("customer_id") @db.Uuid
  createdAt  DateTime       @default(now()) @map("created_at")
  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      WishlistItem[]

  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @default(uuid()) @db.Uuid
  wishlistId String   @map("wishlist_id") @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
  @@index([productId])
  @@map("wishlist_items")
}

model Seller {
  id                           String                   @id @default(uuid()) @db.Uuid
  userId                       String                   @unique @map("user_id") @db.Uuid
  sellerType                   SellerType               @map("seller_type")
  storeName                    String                   @map("store_name")
  slug                         String                   @unique
  status                       SellerStatus             @default(DRAFT)
  approvalStatus               ApprovalStatus           @default(DRAFT) @map("approval_status")
  commissionType               CommissionType           @default(MANUAL) @map("commission_type")
  commissionValue              Int?                     @map("commission_value")
  subscriptionPlanId           String?                  @map("subscription_plan_id") @db.Uuid
  subscriptionStatus           SellerSubscriptionStatus @default(ACTIVE) @map("subscription_status")
  subscriptionStartedAt        DateTime?                @map("subscription_started_at")
  subscriptionCurrentPeriodEnd DateTime?                @map("subscription_current_period_end")
  createdAt                    DateTime                 @default(now()) @map("created_at")
  updatedAt                    DateTime                 @updatedAt @map("updated_at")
  deletedAt                    DateTime?                @map("deleted_at")
  user                         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionPlan             SellerSubscriptionPlan?  @relation("SellerCurrentSubscriptionPlan", fields: [subscriptionPlanId], references: [id])
  subscriptions                SellerSubscription[]
  subscriptionPayments         SellerSubscriptionPayment[]
  profile                      SellerProfile?
  addresses                    SellerAddress[]
  documents                    SellerDocument[]
  products                     Product[]
  cartItems                    CartItem[]
  orderItems                   OrderItem[]
  orderSplits                  OrderSellerSplit[]
  orderShipments               OrderShipment[]
  orderShipmentPackages        OrderShipmentPackage[]
  courierConsignments          CourierConsignment[]
  courierConsignmentPackages   CourierConsignmentPackage[]
  courierShipments             CourierShipment[]
  courierCodRemittances        CourierCodRemittance[]
  courierProviderSettings      SellerCourierProviderSetting[]
  b2bEnquiries                 B2BEnquiry[]
  commissionRules              CommissionRule[]
  payoutProfile                SellerPayoutProfile?
  ledgerEntries                SellerLedgerEntry[]
  payouts                      SellerPayout[]
  statements                   SellerStatement[]

  @@index([status])
  @@index([approvalStatus])
  @@index([sellerType])
  @@index([subscriptionPlanId])
  @@index([subscriptionStatus])
  @@index([deletedAt, createdAt])
  @@index([status, approvalStatus, createdAt])
  @@map("sellers")
}

model SellerProfile {
  id                String              @id @default(uuid()) @db.Uuid
  sellerId          String              @unique @map("seller_id") @db.Uuid
  logoUrl           String?             @map("logo_url")
  bannerUrl         String?             @map("banner_url")
  description       String?
  businessLegalName String?             @map("business_legal_name")
  businessType      SellerBusinessType? @map("business_type")
  gstNumber         String?             @map("gst_number")
  panNumber         String?             @map("pan_number")
  contactName       String              @map("contact_name")
  contactPhone      String              @map("contact_phone")
  contactEmail      String              @map("contact_email")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  seller            Seller              @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@map("seller_profiles")
}

model SellerAddress {
  id            String   @id @default(uuid()) @db.Uuid
  sellerId      String   @map("seller_id") @db.Uuid
  line1         String
  line2         String?
  area          String?
  city          String
  state         String
  pincode       String
  country       String   @default("India")
  countryCode   String   @default("IN") @map("country_code")
  stateCode     String?  @map("state_code")
  cityCode      String?  @map("city_code")
  localAreaCode String?  @map("local_area_code")
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  locationSource LocationSource? @map("location_source")
  accuracyMeters Decimal? @map("accuracy_meters") @db.Decimal(10, 2)
  locationConfidenceScore Decimal? @map("location_confidence_score") @db.Decimal(5, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  seller        Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([city, area])
  @@index([countryCode, stateCode, cityCode])
  @@map("seller_addresses")
}

model SellerCourierProviderSetting {
  id                 String                 @id @default(uuid()) @db.Uuid
  sellerId           String                 @map("seller_id") @db.Uuid
  providerCode       String                 @map("provider_code")
  pickupLocationName String?                @map("pickup_location_name")
  isActive           Boolean                @default(true) @map("is_active")
  settingsSnapshot   Json?                  @map("settings_snapshot")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  seller             Seller                 @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  provider           CourierProviderSetting @relation(fields: [providerCode], references: [providerCode], onDelete: Cascade)

  @@unique([sellerId, providerCode])
  @@index([providerCode, isActive])
  @@index([sellerId, isActive])
  @@map("seller_courier_provider_settings")
}

model SellerDocument {
  id           String         @id @default(uuid()) @db.Uuid
  sellerId     String         @map("seller_id") @db.Uuid
  documentType String         @map("document_type")
  fileUrl      String         @map("file_url")
  status       DocumentStatus @default(PENDING)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  seller       Seller         @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, documentType])
  @@index([sellerId])
  @@index([status])
  @@map("seller_documents")
}

model SellerPayoutProfile {
  id                String   @id @default(uuid()) @db.Uuid
  sellerId          String   @unique @map("seller_id") @db.Uuid
  accountHolderName String?  @map("account_holder_name")
  bankName          String?  @map("bank_name")
  accountNumber     String?  @map("account_number")
  ifscCode          String?  @map("ifsc_code")
  upiId             String?  @map("upi_id")
  isVerified        Boolean  @default(false) @map("is_verified")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  seller            Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@map("seller_payout_profiles")
}

model SellerSubscriptionPlan {
  id                    String                         @id @default(uuid()) @db.Uuid
  code                  String                         @unique
  name                  String
  description           String?
  pricePaise            Int                            @default(0) @map("price_paise")
  currency              String                         @default("INR")
  billingCycle          SellerSubscriptionBillingCycle @default(MONTHLY) @map("billing_cycle")
  productLimit          Int?                           @map("product_limit")
  featuredProductLimit  Int?                           @map("featured_product_limit")
  b2bEnquiryLimit       Int?                           @map("b2b_enquiry_limit")
  commissionDiscountBps Int                            @default(0) @map("commission_discount_bps")
  providerPlanId        String?                        @map("provider_plan_id")
  providerPlanVersion   Int                            @default(1) @map("provider_plan_version")
  providerPlanSyncedAt  DateTime?                      @map("provider_plan_synced_at")
  providerPlanSnapshot  Json?                          @map("provider_plan_snapshot")
  isDefault             Boolean                        @default(false) @map("is_default")
  isActive              Boolean                        @default(true) @map("is_active")
  sortOrder             Int                            @default(100) @map("sort_order")
  createdAt             DateTime                       @default(now()) @map("created_at")
