model NotificationLog {
  id                String              @id @default(uuid()) @db.Uuid
  userId            String?             @map("user_id") @db.Uuid
  channel           NotificationChannel
  templateCode      String              @map("template_code")
  eventCode         String?             @map("event_code")
  recipientType     EmailRecipientType? @map("recipient_type")
  triggerRuleId     String?             @map("trigger_rule_id") @db.Uuid
  recipient         String
  subject           String?
  body              String?
  variables         Json?
  status            NotificationStatus  @default(PENDING)
  providerMessageId String?             @map("provider_message_id")
  errorMessage      String?             @map("error_message")
  scheduledFor      DateTime?           @map("scheduled_for")
  sentAt            DateTime?           @map("sent_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  user              User?               @relation(fields: [userId], references: [id])
  triggerRule       EmailTriggerRule?   @relation(fields: [triggerRuleId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([templateCode])
  @@index([eventCode])
  @@index([recipientType])
  @@index([triggerRuleId])
  @@index([status])
  @@index([scheduledFor])
  @@index([createdAt])
  @@index([channel, createdAt])
  @@index([status, createdAt])
  @@index([templateCode, createdAt])
  @@index([eventCode, createdAt])
  @@index([recipientType, createdAt])
  @@index([triggerRuleId, status, createdAt])
  @@map("notification_logs")
}

