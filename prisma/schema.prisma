model User {
  id                                       String                             @id @default(uuid()) @db.Uuid
  clerkUserId                              String?                            @unique @map("clerk_user_id")
  email                                    String                             @unique
  phone                                    String?
  fullName                                 String?                            @map("full_name")
  status                                   UserStatus                         @default(ACTIVE)
  createdAt                                DateTime                           @default(now()) @map("created_at")
  updatedAt                                DateTime                           @updatedAt @map("updated_at")
  customer                                 Customer?
  seller                                   Seller?
  businessBuyer                            BusinessBuyer?
  cancelledServiceBookings                 ServiceBooking[]                   @relation("ServiceBookingCancelledBy")
  confirmedServiceBookings                 ServiceBooking[]                   @relation("ServiceBookingCompletionConfirmedBy")
  serviceCashCollections                   ServicePayment[]                   @relation("ServicePaymentCashCollectedBy")
  serviceQuotesSent                        ServiceQuote[]                     @relation("ServiceQuoteSentBy")
  serviceQuotesWithdrawn                   ServiceQuote[]                     @relation("ServiceQuoteWithdrawnBy")
  serviceDisputesRaised                    ServiceDispute[]                   @relation("ServiceDisputeRaisedBy")
  serviceDisputesResolved                  ServiceDispute[]                   @relation("ServiceDisputeResolvedBy")
  createdServiceRefundRequests             ServiceRefundRequest[]             @relation("ServiceRefundRequestCreatedBy")
  reviewedServiceRefundRequests            ServiceRefundRequest[]             @relation("ServiceRefundRequestReviewedBy")
  createdServiceRefundTransactions         ServiceRefundTransaction[]         @relation("ServiceRefundTransactionCreatedBy")
  serviceReceivablesVerified               ServiceSellerReceivable[]          @relation("ServiceReceivableVerifiedBy")
  serviceReceivablesDisputed               ServiceSellerReceivable[]          @relation("ServiceReceivableDisputedBy")
  serviceReceivablesResolved               ServiceSellerReceivable[]          @relation("ServiceReceivableResolvedBy")
  serviceReceivableWaiverRequests          ServiceSellerReceivable[]          @relation("ServiceReceivableWaiverRequestedBy")
  serviceReceivableWaiverApprovals         ServiceSellerReceivable[]          @relation("ServiceReceivableWaiverApprovedBy")
  serviceReceivableEvents                  ServiceSellerReceivableEvent[]     @relation("ServiceReceivableEventActor")
  serviceReviewReplies                     ServiceReviewReply[]               @relation("ServiceReviewReplyProvider")
  userRoles                                UserRole[]
  inventoryMovements                       InventoryMovement[]
  orderStatusEvents                        OrderStatusEvent[]
  deliveryEvents                           DeliveryEvent[]
  assignedDeliveries                       DeliveryDetail[]                   @relation("DeliveryPartnerAssignments")
  assignedShipments                        OrderShipment[]                    @relation("ShipmentDeliveryPartnerAssignments")
  codCollections                           DeliveryDetail[]                   @relation("DeliveryCodCollectedBy")
  shipmentCodCollections                   OrderShipment[]                    @relation("ShipmentCodCollectedBy")
  codVerifications                         DeliveryDetail[]                   @relation("DeliveryCodVerifiedBy")
  shipmentCodVerifications                 OrderShipment[]                    @relation("ShipmentCodVerifiedBy")
  courierCodRemittanceVerifications        CourierCodRemittance[]             @relation("CourierCodRemittanceVerifiedBy")
  deliveryProfile                          DeliveryPartnerProfile?
  deliveryAssignmentAttempts               DeliveryAssignmentAttempt[]        @relation("DeliveryAssignmentAttemptPartner")
  createdDeliveryAssignmentAttempts        DeliveryAssignmentAttempt[]        @relation("DeliveryAssignmentAttemptAssignedBy")
  deliveryAttempts                         DeliveryAttempt[]
  deliveryWalletEntries                    DeliveryPartnerWalletEntry[]       @relation("DeliveryPartnerWalletEntries")
  createdDeliveryWalletEntries             DeliveryPartnerWalletEntry[]       @relation("DeliveryPartnerWalletEntryCreatedBy")
  deliveryPartnerPayouts                   DeliveryPartnerPayout[]            @relation("DeliveryPartnerPayoutPartner")
  requestedDeliveryPartnerPayouts          DeliveryPartnerPayout[]            @relation("DeliveryPartnerPayoutRequestedBy")
  approvedDeliveryPartnerPayouts           DeliveryPartnerPayout[]            @relation("DeliveryPartnerPayoutApprovedBy")
  paidDeliveryPartnerPayouts               DeliveryPartnerPayout[]            @relation("DeliveryPartnerPayoutPaidBy")
  deliveryPartnerApplications              DeliveryPartnerApplication[]       @relation("DeliveryPartnerApplicationApplicant")
  reviewedDeliveryPartnerApplications      DeliveryPartnerApplication[]       @relation("DeliveryPartnerApplicationReviewer")
  b2bResponses                             B2BEnquiryResponse[]
  createdB2BOrders                         B2BOrder[]                         @relation("B2BOrderCreatedBy")
  b2bOrderEvents                           B2BOrderEvent[]                    @relation("B2BOrderEventActor")
  submittedB2BPaymentProofs                B2BPaymentProof[]                  @relation("B2BPaymentProofSubmittedBy")
  reviewedB2BPaymentProofs                 B2BPaymentProof[]                  @relation("B2BPaymentProofReviewedBy")
  verifiedB2BPayments                      B2BOrder[]                         @relation("B2BOrderPaymentVerifiedBy")
  unlockedB2BFulfilments                   B2BOrder[]                         @relation("B2BOrderFulfilmentUnlockedBy")
  generatedB2BProformaRevisions            B2BProformaInvoiceRevision[]       @relation("B2BProformaRevisionGeneratedBy")
  b2bAdminAuditLogs                        B2BAdminAuditLog[]                 @relation("B2BAdminAuditLogActor")
  supportRequests                          SupportRequest[]
  notificationLogs                         NotificationLog[]
  customerPushTokens                       CustomerPushToken[]
  sellerPushTokens                         SellerPushToken[]
  createdPushNotificationCampaigns         PushNotificationCampaign[]         @relation("PushCampaignCreatedBy")
  updatedPushNotificationCampaigns         PushNotificationCampaign[]         @relation("PushCampaignUpdatedBy")
  auditLogs                                AuditLog[]
  adminCredential                          AdminCredential?
  adminSessions                            AdminSession[]
  createdDeals                             Deal[]                             @relation("DealCreatedBy")
  updatedDeals                             Deal[]                             @relation("DealUpdatedBy")
  createdCoupons                           Coupon[]                           @relation("CouponCreatedBy")
  updatedCoupons                           Coupon[]                           @relation("CouponUpdatedBy")
  couponAdjustments                        CouponRedemptionAdjustment[]       @relation("CouponAdjustmentCreatedBy")
  moderatedProductReviews                  ProductReview[]                    @relation("ProductReviewModerator")
