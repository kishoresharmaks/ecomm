  status            PushNotificationBatchStatus @default(PENDING)
  recipientTokenIds String[]                    @default([]) @map("recipient_token_ids") @db.Uuid
  ticketIds         String[]                    @default([]) @map("ticket_ids")
  ticketErrors      Json?                       @map("ticket_errors")
  claimedBy         String?                     @map("claimed_by")
  claimedAt         DateTime?                   @map("claimed_at")
  doneAt            DateTime?                   @map("done_at")
  attemptCount      Int                         @default(0) @map("attempt_count")
  createdAt         DateTime                    @default(now()) @map("created_at")
  updatedAt         DateTime                    @updatedAt @map("updated_at")
  campaign          PushNotificationCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  logs              NotificationLog[]
  receipts          PushNotificationReceipt[]

  @@index([campaignId, status])
  @@index([status, claimedAt])
  @@index([createdAt])
  @@map("push_notification_campaign_batches")
}

model PushNotificationReceipt {
  id                  String                         @id @default(uuid()) @db.Uuid
  notificationLogId   String                         @unique @map("notification_log_id") @db.Uuid
  customerPushTokenId String?                        @map("customer_push_token_id") @db.Uuid
  campaignBatchId     String?                        @map("campaign_batch_id") @db.Uuid
  ticketId            String?                        @map("ticket_id")
  receiptId           String?                        @map("receipt_id")
  status              PushNotificationReceiptStatus  @default(PENDING)
  providerStatus      String?                        @map("provider_status")
  providerDetails     Json?                          @map("provider_details")
  errorCode           String?                        @map("error_code")
  errorMessage        String?                        @map("error_message")
  checkAfter          DateTime?                      @map("check_after")
  checkedAt           DateTime?                      @map("checked_at")
  createdAt           DateTime                       @default(now()) @map("created_at")
  updatedAt           DateTime                       @updatedAt @map("updated_at")
  notificationLog     NotificationLog                @relation(fields: [notificationLogId], references: [id], onDelete: Cascade)
  customerPushToken   CustomerPushToken?             @relation(fields: [customerPushTokenId], references: [id], onDelete: SetNull)
  campaignBatch       PushNotificationCampaignBatch? @relation(fields: [campaignBatchId], references: [id], onDelete: SetNull)

  @@index([status, checkAfter])
  @@index([ticketId])
  @@index([customerPushTokenId])
  @@index([campaignBatchId])
  @@map("push_notification_receipts")
}

model EmailSetting {
  id              String   @id @default(uuid()) @db.Uuid
  provider        String
  senderName      String   @map("sender_name")
  senderEmail     String   @map("sender_email")
  adminRecipients String?  @map("admin_recipients")
  isEnabled       Boolean  @default(false) @map("is_enabled")
  providerConfig  Json?    @map("provider_config")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("email_settings")
}

model Setting {
  id        String           @id @default(uuid()) @db.Uuid
  key       String           @unique
  value     Json
  valueType SettingValueType @map("value_type")
  group     String
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@index([group])
  @@map("settings")
}

model ShippingRateCard {
  id                    String                   @id @default(uuid()) @db.Uuid
  name                  String
  deliveryMode          DeliveryMode             @map("delivery_mode")
  countryCode           String?                  @map("country_code")
  stateCode             String?                  @map("state_code")
  cityCode              String?                  @map("city_code")
  pincode               String?
  localAreaCode         String?                  @map("local_area_code")
  minSubtotalPaise      Int?                     @map("min_subtotal_paise")
  maxSubtotalPaise      Int?                     @map("max_subtotal_paise")
  shippingChargePaise   Int                      @default(0) @map("shipping_charge_paise")
  freeAbovePaise        Int?                     @map("free_above_paise")
  codSurchargeType      ShippingCodSurchargeType @default(NONE) @map("cod_surcharge_type")
  codSurchargeFlatPaise Int                      @default(0) @map("cod_surcharge_flat_paise")
  codSurchargeBps       Int                      @default(0) @map("cod_surcharge_bps")
  priority              Int                      @default(100)
  isActive              Boolean                  @default(true) @map("is_active")
  notes                 String?
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")

  @@index([deliveryMode, isActive, priority])
  @@index([deliveryMode, isActive, countryCode, stateCode, cityCode, pincode, localAreaCode])
  @@index([deliveryMode, isActive, minSubtotalPaise, maxSubtotalPaise])
  @@index([countryCode])
  @@index([stateCode])
  @@index([cityCode])
  @@index([pincode])
  @@index([localAreaCode])
  @@index([priority])
  @@map("shipping_rate_cards")
}

model CourierProviderSetting {
  id                      String                         @id @default(uuid()) @db.Uuid
  providerCode            String                         @unique @map("provider_code")
  displayName             String                         @map("display_name")
  mode                    CourierProviderMode            @default(MANUAL)
  isActive                Boolean                        @default(false) @map("is_active")
  serviceableCountryCodes String[]                       @default([]) @map("serviceable_country_codes")
  credentialsConfigured   Boolean                        @default(false) @map("credentials_configured")
  webhookSecretConfigured Boolean                        @default(false) @map("webhook_secret_configured")
  settingsSnapshot        Json?                          @map("settings_snapshot")
  notes                   String?
  createdAt               DateTime                       @default(now()) @map("created_at")
  updatedAt               DateTime                       @updatedAt @map("updated_at")
  courierShipments        CourierShipment[]
  courierConsignments     CourierConsignment[]
  courierCodRemittances   CourierCodRemittance[]
  sellerProviderSettings  SellerCourierProviderSetting[]

  @@index([isActive, providerCode])
  @@index([mode])
  @@map("courier_provider_settings")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id") @db.Uuid
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")
  actor       User?    @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, createdAt])
  @@map("audit_logs")
}
